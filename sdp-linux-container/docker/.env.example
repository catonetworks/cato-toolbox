# Cato SDP container — NON-SECRET identifiers. Copy to .env and fill in.
#
# .env is gitignored. It holds ONLY the non-secret account/user, which Compose reads for variable
# interpolation. The PASSWORD does NOT go here — it is a file-based Docker secret: create
# secrets/cato_password from secrets/cato_password.example (see DEPLOYMENT.md).
#
# Use a password-ACTIVATED Cato SDP user (created in the CMA, then activated by the user via an
# activation email — the admin cannot set the password). OAuth/SSO-only users cannot authenticate
# headlessly.
CATO_ACCOUNT=your-cato-account
CATO_USER=user@example.com
